{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noImplicitAny": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "allowJs": false,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "_shared/cloud-types.ts",
    "wx-server-sdk.d.ts",
    "ai/index.ts",
    "board/index.ts",
    "backfill-streaks/index.ts",
    "backfill-streaks/streak.d.ts",
    "habit/index.ts",
    "habit/streak.d.ts",
    "notify/index.ts",
    "stats/index.ts",
    "stats/streak.d.ts",
    "ritual/index.ts",
    "ritual/streak.d.ts",
    "journey/index.ts",
    "user/index.ts",
    "user/nickName.d.ts"
  ]
}
