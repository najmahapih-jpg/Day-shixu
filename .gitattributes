# Default: normalize all text files to LF in repository
* text=auto eol=lf

# Windows shell scripts should keep CRLF for better local compatibility
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets (do not normalize line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.mp3 binary
*.mp4 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.pdf binary
