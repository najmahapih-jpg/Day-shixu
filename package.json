{
  "scripts": {
    "sync:cloudfunctions": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-cloudfunctions.ps1",
    "fix:mp-config": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-mp-config.ps1",
    "prepare:devtools": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-devtools-project.ps1",
    "prepare:wechat": "npm run fix:mp-config && npm run prepare:devtools",
    "set:cloud-env": "powershell -ExecutionPolicy Bypass -File ./scripts/set-cloud-env.ps1",
    "env:list": "powershell -ExecutionPolicy Bypass -File ./scripts/set-cloud-env.ps1 -ListAvailable",
    "env:use": "powershell -ExecutionPolicy Bypass -File ./scripts/set-cloud-env.ps1",
    "cf:list": "powershell -ExecutionPolicy Bypass -File ./scripts/cloudbase-fn.ps1 list",
    "cf:deps": "powershell -ExecutionPolicy Bypass -File ./scripts/install-cloudfunction-deps.ps1",
    "cf:sync:shared": "node cloudfunctions/scripts/sync-shared.js",
    "cf:check:shared": "jest cloudfunctions/__tests__/streak-parity.test.js",
    "precf:deploy:all": "npm run cf:sync:shared",
    "cf:deploy:all": "powershell -ExecutionPolicy Bypass -File ./scripts/cloudbase-fn.ps1 deployAll",
    "precf:deploy:one": "npm run cf:sync:shared",
    "cf:deploy:one": "powershell -ExecutionPolicy Bypass -File ./scripts/cloudbase-fn.ps1 deploy",
    "cf:list:changed": "powershell -ExecutionPolicy Bypass -File ./scripts/cloudbase-fn.ps1 listChanged",
    "precf:deploy:changed": "npm run cf:sync:shared",
    "cf:deploy:changed": "powershell -ExecutionPolicy Bypass -File ./scripts/cloudbase-fn.ps1 deployChanged",
    "predeploy:cloud:all": "npm run cf:sync:shared",
    "deploy:cloud:all": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-cloud-all.ps1",
    "cf:deploy:user": "powershell -ExecutionPolicy Bypass -File ./scripts/cloudbase-fn.ps1 deploy user",
    "wx:upload": "node scripts/upload-miniprogram.js",
    "release:wechat": "powershell -ExecutionPolicy Bypass -File ./scripts/release-wechat.ps1",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit -p cloudfunctions/tsconfig.json",
    "build:cloudfunctions:ts": "tsc -p cloudfunctions/tsconfig.json",
    "test": "jest",
    "test:habit": "jest cloudfunctions/habit",
    "test:user": "jest cloudfunctions/user",
    "test:ritual": "jest cloudfunctions/ritual",
    "test:stats": "jest cloudfunctions/stats",
    "clean:dev-artifacts": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-dev-artifacts.ps1",
    "check:hygiene": "powershell -ExecutionPolicy Bypass -File ./scripts/check-hygiene.ps1",
    "check:gate": "npm test && powershell -ExecutionPolicy Bypass -File ./scripts/preflight-check.ps1 && npm run check:hygiene",
    "release:check": "powershell -ExecutionPolicy Bypass -File ./scripts/release-context-check.ps1",
    "release:guarded": "npm run clean:dev-artifacts && npm run check:gate && npm run release:check && powershell -ExecutionPolicy Bypass -File ./scripts/release-wechat.ps1"
  },
  "dependencies": {
    "@qiun/ucharts": "^2.5.0-20230101",
    "grapheme-splitter": "1.0.4",
    "pinia": "^3.0.4"
  },
  "engines": {
    "node": "18.x"
  },
  "devDependencies": {
    "@cloudbase/cli": "^2.12.4",
    "@phosphor-icons/core": "^2.1.1",
    "jest": "^29.7.0",
    "less": "^3.13.1",
    "miniprogram-ci": "^1.9.0",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6"
  }
}
